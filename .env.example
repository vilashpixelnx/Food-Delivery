# ─── Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only commit .env.example

# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────
# Get your URI from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.mongodb.net/pani-puri-db

# ─── JWT ──────────────────────────────────────────────────────
# Use any strong random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRES_IN=7d

# ─── Frontend URL ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Razorpay (Phase 7) ───────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── WhatsApp API (Phase 16) ──────────────────────────────────
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
